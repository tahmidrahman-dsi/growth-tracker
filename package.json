{
  "name": "growth-tracker",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "build": "pnpm -r run build",
    "prestart": "[ -f packages/server/.env ] || cp .env.example packages/server/.env",
    "start": "docker compose up -d && wait-on tcp:localhost:5432 && pnpm db:migrate && pnpm dev",
    "db:migrate": "pnpm --filter @growth-tracker/server exec prisma migrate dev --name init",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v"
  },
  "devDependencies": {
    "wait-on": "^7.2.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  }
}
